// llm — Multi-provider LLM API client
//
// Supports:
//   cf:@cf/meta/llama-3.3-70b-instruct-fp8-fast    Cloudflare Workers AI
//   anthropic:claude-sonnet-4-6                      Anthropic Messages API
//   openrouter:meta-llama/llama-3.3-70b-instruct    OpenRouter
//   openai:gpt-4o                                   OpenAI
//   claude-sonnet-4-6                               Claude CLI (fallback)
//
// Each provider reads its API key from environment variables.

import env
import http
import json
import process

// ── Types ──

type ModelSpec = {
  provider: String,
  model: String,
}

// ── Parsing ──

fn parse_model(spec: String) -> ModelSpec = {
  let colon = string.index_of(spec, ":")
  match colon {
    none => ModelSpec { provider: "claude", model: spec }
    some(i) => ModelSpec {
      provider: string.take(spec, i),
      model: string.drop(spec, i + 1),
    }
  }
}

fn display_model(spec: ModelSpec) -> String =
  if spec.provider == "claude" then spec.model
  else spec.provider + ":" + spec.model

// ── Env helpers ──

effect fn require_env(key: String) -> Result[String, String] = {
  let val = env.get(key)
  match val {
    none => err("missing env var: " + key)
    some(v) => if v == "" then err("empty env var: " + key) else ok(v)
  }
}

fn option_to_result(opt: Option[String], msg: String) -> Result[String, String] =
  match opt {
    some(v) => ok(v)
    none => err(msg)
  }

// ── Chat message builder ──

fn chat_messages(system: String, user: String) -> Value =
  json.array([
    json.object([("role", json.from_string("system")), ("content", json.from_string(system))]),
    json.object([("role", json.from_string("user")), ("content", json.from_string(user))]),
  ])

// ── Cloudflare Workers AI ──
//
// POST https://api.cloudflare.com/client/v4/accounts/{id}/ai/run/{model}
// Authorization: Bearer {key}
// Response: {"result": {"response": "..."}}

effect fn call_cf(model: String, system: String, user_prompt: String) -> Result[String, String] = {
  match require_env("CF_ACCOUNT_ID") {
    err(e) => err(e)
    ok(account_id) => match require_env("CLOUDFLARE_API_KEY") {
      err(e) => err(e)
      ok(api_key) => {
        let url = "https://api.cloudflare.com/client/v4/accounts/" + account_id + "/ai/run/" + model
        let body = json.stringify(json.object([
          ("messages", chat_messages(system, user_prompt)),
        ]))
        let headers: Map[String, String] = [
          "Authorization": "Bearer " + api_key,
          "Content-Type": "application/json",
        ]
        match http.request("POST", url, body, headers) {
          err(e) => err("cf http error: " + e)
          ok(raw) => match json.parse(raw) {
            err(e) => err("cf json parse error: " + e)
            ok(parsed) =>
              json.get(parsed, "result")
                |> option.flat_map((r) => json.get_string(r, "response"))
                |> option.map((s) => string.trim(s))
                |> option_to_result("cf: no result.response in response")
          }
        }
      }
    }
  }
}

// ── OpenAI-compatible (OpenAI, OpenRouter) ──
//
// POST {base_url}/chat/completions
// Authorization: Bearer {key}
// Response: {"choices": [{"message": {"content": "..."}}]}

effect fn call_openai_compat(base_url: String, api_key: String, model: String, system: String, user_prompt: String) -> Result[String, String] = {
  let url = base_url + "/chat/completions"
  let body = json.stringify(json.object([
    ("model", json.from_string(model)),
    ("messages", chat_messages(system, user_prompt)),
    ("max_tokens", json.from_int(4096)),
  ]))
  let headers: Map[String, String] = [
    "Authorization": "Bearer " + api_key,
    "Content-Type": "application/json",
  ]
  match http.request("POST", url, body, headers) {
    err(e) => err("openai http error: " + e)
    ok(raw) => match json.parse(raw) {
      err(e) => err("openai json parse error: " + e)
      ok(parsed) =>
        json.get_array(parsed, "choices")
          |> option.flat_map((choices) => list.first(choices))
          |> option.flat_map((choice) => json.get(choice, "message"))
          |> option.flat_map((msg) => json.get_string(msg, "content"))
          |> option.map((s) => string.trim(s))
          |> option_to_result("openai: no choices[0].message.content in response")
    }
  }
}

effect fn call_openai(model: String, system: String, user_prompt: String) -> Result[String, String] =
  match require_env("OPENAI_API_KEY") {
    err(e) => err(e)
    ok(key) => call_openai_compat("https://api.openai.com/v1", key, model, system, user_prompt)
  }

effect fn call_openrouter(model: String, system: String, user_prompt: String) -> Result[String, String] =
  match require_env("OPENROUTER_API_KEY") {
    err(e) => err(e)
    ok(key) => call_openai_compat("https://openrouter.ai/api/v1", key, model, system, user_prompt)
  }

// ── Anthropic Messages API ──
//
// POST https://api.anthropic.com/v1/messages
// x-api-key: {key}
// anthropic-version: 2023-06-01
// Response: {"content": [{"type": "text", "text": "..."}]}

effect fn call_anthropic(model: String, system: String, user_prompt: String) -> Result[String, String] =
  match require_env("ANTHROPIC_API_KEY") {
    err(e) => err(e)
    ok(api_key) => {
      let url = "https://api.anthropic.com/v1/messages"
      let body = json.stringify(json.object([
        ("model", json.from_string(model)),
        ("max_tokens", json.from_int(4096)),
        ("system", json.from_string(system)),
        ("messages", json.array([
          json.object([("role", json.from_string("user")), ("content", json.from_string(user_prompt))]),
        ])),
      ]))
      let headers: Map[String, String] = [
        "x-api-key": api_key,
        "anthropic-version": "2023-06-01",
        "Content-Type": "application/json",
      ]
      match http.request("POST", url, body, headers) {
        err(e) => err("anthropic http error: " + e)
        ok(raw) => match json.parse(raw) {
          err(e) => err("anthropic json parse error: " + e)
          ok(parsed) =>
            json.get_array(parsed, "content")
              |> option.flat_map((blocks) => list.first(blocks))
              |> option.flat_map((block) => json.get_string(block, "text"))
              |> option.map((s) => string.trim(s))
              |> option_to_result("anthropic: no content[0].text in response")
        }
      }
    }
  }

// ── Claude CLI (fallback for prefix-less model names) ──

effect fn call_claude_cli(model: String, system: String, user_prompt: String) -> Result[String, String] =
  match process.exec("claude", ["--model", model, "--print", "--system-prompt", system, user_prompt]) {
    err(e) => err("claude exec failed: " + e)
    ok(raw) => ok(string.trim(raw))
  }

// ── Unified dispatch ──

effect fn call(spec: String, system: String, user_prompt: String) -> Result[String, String] = {
  let m = parse_model(spec)
  if m.provider == "cf" then call_cf(m.model, system, user_prompt)
  else if m.provider == "anthropic" then call_anthropic(m.model, system, user_prompt)
  else if m.provider == "openrouter" then call_openrouter(m.model, system, user_prompt)
  else if m.provider == "openai" then call_openai(m.model, system, user_prompt)
  else if m.provider == "claude" then call_claude_cli(m.model, system, user_prompt)
  else err("unknown provider: " + m.provider)
}

// ── Tests ──

test "parse_model with prefix" {
  let m = parse_model("cf:@cf/meta/llama-3.3-70b")
  assert_eq(m.provider, "cf")
  assert_eq(m.model, "@cf/meta/llama-3.3-70b")
}

test "parse_model without prefix" {
  let m = parse_model("claude-sonnet-4-6")
  assert_eq(m.provider, "claude")
  assert_eq(m.model, "claude-sonnet-4-6")
}

test "parse_model openrouter" {
  let m = parse_model("openrouter:meta-llama/llama-3.3-70b-instruct")
  assert_eq(m.provider, "openrouter")
  assert_eq(m.model, "meta-llama/llama-3.3-70b-instruct")
}

test "parse_model anthropic" {
  let m = parse_model("anthropic:claude-sonnet-4-6")
  assert_eq(m.provider, "anthropic")
  assert_eq(m.model, "claude-sonnet-4-6")
}

test "display_model with prefix" {
  assert_eq(display_model(ModelSpec { provider: "cf", model: "@cf/meta/llama" }), "cf:@cf/meta/llama")
}

test "display_model claude" {
  assert_eq(display_model(ModelSpec { provider: "claude", model: "claude-sonnet-4-6" }), "claude-sonnet-4-6")
}
