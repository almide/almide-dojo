// dojo — Almide Dojo harness
//
// Multi-provider LLM harness for MSR measurement.
// Supports Cloudflare Workers AI, Anthropic, OpenRouter, OpenAI, and Claude CLI.
//
// Usage:
//   almide run src/main.almd -- <task-name> [provider:model]
//   almide run src/main.almd -- all [provider:model]
//
// Model formats:
//   cf:@cf/meta/llama-3.3-70b-instruct-fp8-fast    Cloudflare Workers AI
//   anthropic:claude-sonnet-4-6                      Anthropic Messages API
//   openrouter:meta-llama/llama-3.3-70b-instruct    OpenRouter (100+ models)
//   openai:gpt-4o                                   OpenAI API
//   claude-sonnet-4-6                               Claude CLI (no prefix)
//
// Environment variables (per provider):
//   CF_ACCOUNT_ID, CLOUDFLARE_API_KEY               Cloudflare Workers AI
//   ANTHROPIC_API_KEY                               Anthropic / Claude CLI
//   OPENROUTER_API_KEY                              OpenRouter
//   OPENAI_API_KEY                                  OpenAI

import env
import fs
import process
import datetime
import almai

// ── Constants ──

let DEFAULT_MODEL = "claude-sonnet-4-6"
let DEFAULT_MAX_RETRIES = 3

let SYSTEM_PROMPT = """
  You are writing Almide. Output ONLY source code, no fences or prose.
  fn name(x: T) -> R = expr. No return; last expression is the value.
  if cond then a else b. match v { P => e, ... }. (x) => expr for lambdas.
  Modules use dot: list.map, string.len. Option[T]: some(v)/none. Result[T,E]: ok(v)/err(e).
  int.to_string(n) for int-to-string. No Char type; single characters are String.
  Lists are immutable: use xs + [item] to append, not list.push (which mutates var and returns Unit).
  list.fold(xs, init, (acc, x) => ...) for reduce. No foldLeft/foldRight.
  """

// ── Types ──

type Task = {
  name: String,
  prompt: String,
  tests: String,
  dir: String,
}

type Attempt = {
  code: String,
  diagnostic: String,
  passed: Bool,
}

type RunResult = {
  task: String,
  model: String,
  success: Bool,
  retries: Int,
  final_diagnostic: String,
  final_code: String,
  attempts: List[Attempt],
}

type AttemptResult = {
  success: Bool,
  code: String,
  diagnostic: String,
}

// ── Task loading ──

let DIFFICULTIES = ["basic", "intermediate", "advanced"]

effect fn load_task(name: String) -> Result[Task, String] =
  load_task_search(name, DIFFICULTIES)

effect fn load_task_search(name: String, levels: List[String]) -> Result[Task, String] =
  if list.is_empty(levels) then
    err("task not found: " + name)
  else {
    let level = list.get(levels, 0) |> option.unwrap_or("")
    let dir = "tasks/" + level + "/" + name
    match fs.read_text(dir + "/prompt.md") {
      err(_) => load_task_search(name, list.drop(levels, 1))
      ok(prompt) => match fs.read_text(dir + "/tests.almd") {
        err(_) => load_task_search(name, list.drop(levels, 1))
        ok(tests) => ok(Task { name: name, prompt: prompt, tests: tests, dir: dir })
      }
    }
  }

// ── Model call (via llm module) ──

fn strip_code_fences(s: String) -> String =
  s
    |> string.split("\n")
    |> list.filter((line) => not string.starts_with(string.trim(line), "```"))
    |> string.join("\n")

fn to_almai_spec(model: String) -> String = {
  // "cf:@cf/meta/..." → "cf/@cf/meta/..."
  // "anthropic:claude-..." → "anthropic/claude-..."
  // "claude-sonnet-4-6" (no prefix) → "anthropic/claude-sonnet-4-6"
  let colon = string.index_of(model, ":")
  match colon {
    some(i) => string.take(model, i) + "/" + string.drop(model, i + 1)
    none => if string.starts_with(model, "claude") then "anthropic/" + model
      else if string.starts_with(model, "gpt") then "openai/" + model
      else "openai/" + model
  }
}

effect fn call_model(model: String, user_prompt: String) -> Result[String, String] = {
  let spec = to_almai_spec(model)
  let opts = almai.defaults() |> almai.with_system(SYSTEM_PROMPT)
  let msgs = [almai.user(user_prompt)]
  match almai.call_with(spec, msgs, opts) {
    err(e) => err(e)
    ok(r) => ok(strip_code_fences(r.content))
  }
}

// ── Compile + test ──
//
// `process.exec` returns Err on non-zero exit (stderr is the error string).
// So a non-zero `almide test` run shows up as an Err with the diagnostic,
// which we translate into a successful `AttemptResult { success: false }`.

effect fn compile_and_test(task: Task, solution: String, attempt: Int) -> Result[AttemptResult, String] = {
  let tmp = env.temp_dir() + "/dojo-" + task.name + "-" + int.to_string(attempt) + ".almd"
  let combined = solution + "\n\n" + task.tests
  match fs.write(tmp, combined) {
    err(_) => err("failed to write temp file: " + tmp)
    ok(_) => match process.exec("almide", ["test", tmp]) {
      ok(_) => ok(AttemptResult { success: true, code: solution, diagnostic: "" })
      err(diag) => ok(AttemptResult { success: false, code: solution, diagnostic: diag })
    }
  }
}

// ── Fix loop ──
//
// fix_loop_step distinguishes:
//   - err(_)  — genuine harness failure (claude CLI missing, fs broken). Abort.
//   - ok(RunResult { success: false, ... }) — model couldn't produce passing
//     code within max_retries. Not an error; gets recorded and we move on.

fn build_retry_prompt(original: String, prev_code: String, diag: String) -> String =
  "Original task:\n\n" + original + "\n\n" +
  "You previously wrote this code:\n\n" + prev_code + "\n\n" +
  "It failed to compile or test. Diagnostic output:\n\n" + diag + "\n\n" +
  "Fix the code and return ONLY the corrected Almide source. No markdown fences, no explanation."

effect fn attempt_once(
  task: Task,
  model: String,
  user_prompt: String,
  attempt: Int,
) -> Result[AttemptResult, String] = {
  match call_model(model, user_prompt) {
    err(e) => err("call_model: " + e)
    ok(code) => compile_and_test(task, code, attempt)
  }
}

effect fn fix_loop_step(
  task: Task,
  model: String,
  max_retries: Int,
  attempt: Int,
  last_code: String,
  last_diag: String,
  acc: List[Attempt],
) -> Result[RunResult, String] = {
  if attempt > max_retries then
    ok(RunResult {
      task: task.name, model: model, success: false,
      retries: max_retries, final_diagnostic: last_diag, final_code: last_code,
      attempts: acc,
    })
  else {
    let user_prompt =
      if attempt == 0 then task.prompt
      else build_retry_prompt(task.prompt, last_code, last_diag)
    match attempt_once(task, model, user_prompt, attempt) {
      err(e) => err("attempt " + int.to_string(attempt) + ": " + e)
      ok(result) => {
        let this_attempt = Attempt { code: result.code, diagnostic: result.diagnostic, passed: result.success }
        let new_acc = acc + [this_attempt]
        if result.success then
          ok(RunResult {
            task: task.name, model: model, success: true,
            retries: attempt, final_diagnostic: "", final_code: result.code,
            attempts: new_acc,
          })
        else
          fix_loop_step(task, model, max_retries, attempt + 1, result.code, result.diagnostic, new_acc)
      }
    }
  }
}

effect fn fix_loop(task: Task, model: String, max_retries: Int) -> Result[RunResult, String] =
  fix_loop_step(task, model, max_retries, 0, "", "", [])

// ── Metrics recording ──
//
// ── Failure classification ──
//
// Each RunResult is classified into a category and (when present) a
// primary diagnostic code. The category drives the dashboard breakdown;
// the code drives the "top diagnostic codes" leaderboard that surfaces
// the diagnostics most likely to mislead an LLM.

fn primary_diagnostic_code(diag: String) -> String =
  match string.index_of(diag, "error[E") {
    none => ""
    some(i) => {
      let after = string.drop(diag, i + 6)
      match string.index_of(after, "]") {
        none => ""
        some(j) => string.take(after, j)
      }
    }
  }

fn category_from_code(code: String) -> String =
  if code == "E001" then "type-error"
  else if code == "E002" then "type-error"
  else if code == "E005" then "type-error"
  else if code == "E003" then "name-error"
  else if code == "E004" then "import-error"
  else "compile-error"

fn classify_failure(diag: String) -> (String, String) = {
  let code = primary_diagnostic_code(diag)
  if code != "" then (category_from_code(code), code)
  else if string.contains(diag, "Expected ") then ("parse-error", "")
  else if string.contains(diag, "panicked") then ("runtime-error", "")
  else if string.contains(diag, "thread '") then ("runtime-error", "")
  else if string.contains(diag, "assertion") then ("wrong-output", "")
  else if string.contains(diag, "test failed") then ("wrong-output", "")
  else if string.contains(diag, "timed out") then ("timeout", "")
  else if string.contains(diag, "Timeout") then ("timeout", "")
  else ("unknown", "")
}

fn classify(result: RunResult) -> (String, String) =
  if result.success then
    (if result.retries == 0 then "pass-1shot" else "pass-retry", "")
  else
    classify_failure(result.final_diagnostic)

// Per-task markdown report at runs/YYYY-MM-DD/<task>.md.
// Summaries only — raw model outputs are not committed by convention.

fn fence_block(lang: String, body: String) -> String =
  "```" + lang + "\n" + body + "\n```\n"

fn render_attempt(idx: Int, attempt: Attempt) -> String = {
  let header = "### Attempt " + int.to_string(idx + 1) +
    (if attempt.passed then " (PASS)" else " (FAIL)") + "\n\n"
  let code_section = fence_block("almide", attempt.code)
  if attempt.passed then header + code_section
  else if attempt.diagnostic == "" then header + code_section
  else header + code_section + "\n**Diagnostic:**\n\n" + fence_block("", attempt.diagnostic)
}

fn render_attempts(attempts: List[Attempt]) -> String =
  if list.is_empty(attempts) then ""
  else {
    let body = attempts
      |> list.enumerate
      |> list.map((entry) => render_attempt(entry.0, entry.1))
      |> string.join("\n")
    "## Attempts\n\n" + body
  }

fn render_report(result: RunResult) -> String = {
  let c = classify(result)
  let code_line = if c.1 == "" then "" else "- **diagnostic code**: `" + c.1 + "`\n"
  "# " + result.task + "\n\n" +
  "- **model**: `" + result.model + "`\n" +
  "- **success**: " + (if result.success then "yes" else "no") + "\n" +
  "- **retries**: " + int.to_string(result.retries) + "\n" +
  "- **category**: " + c.0 + "\n" +
  code_line + "\n" +
  render_attempts(result.attempts)
}

fn model_slug(model: String) -> String =
  model
    |> string.replace("/", "_")
    |> string.replace(":", "_")
    |> string.replace("@", "")
    |> string.replace(".", "-")

effect fn write_metrics(result: RunResult) -> Result[String, String] = {
  let date = datetime.format(env.unix_timestamp(), "YYYY-MM-DD")
  let slug = model_slug(result.model)
  let dir = "runs/" + date + "/" + slug
  match fs.mkdir_p(dir) {
    err(_) => err("failed to create " + dir)
    ok(_) => {
      let path = dir + "/" + result.task + ".md"
      match fs.write(path, render_report(result)) {
        err(_) => err("failed to write " + path)
        ok(_) => ok(path)
      }
    }
  }
}

// ── CLI ──

fn bool_str(b: Bool) -> String =
  if b then "yes" else "no"

effect fn print_usage() -> Unit = {
  println("Almide Dojo harness")
  println("")
  println("Usage:")
  println("  almide run src/main.almd -- <task-name> [provider:model]")
  println("  almide run src/main.almd -- all [provider:model]")
  println("")
  println("Providers:")
  println("  cf:@cf/meta/llama-3.3-70b-instruct-fp8-fast")
  println("  anthropic:claude-sonnet-4-6")
  println("  openrouter:meta-llama/llama-3.3-70b-instruct")
  println("  openai:gpt-4o")
  println("  claude-sonnet-4-6  (Claude CLI, no prefix)")
}

effect fn print_result(result: RunResult) -> Unit = {
  println("")
  println("── Result ──")
  println("  task:    " + result.task)
  println("  model:   " + result.model)
  println("  success: " + bool_str(result.success))
  println("  retries: " + int.to_string(result.retries))
  if result.success then {
    println("")
    println("Task passed.")
  } else {
    println("")
    println("Final diagnostic:")
    println(result.final_diagnostic)
  }
}

effect fn run_task(task_name: String, model: String) -> Result[RunResult, String] = {
  println("Loading task: " + task_name)
  match load_task(task_name) {
    err(e) => err("load task: " + e)
    ok(task) => {
      println("Model:    " + model)
      println("Retries:  " + int.to_string(DEFAULT_MAX_RETRIES))
      println("")
      match fix_loop(task, model, DEFAULT_MAX_RETRIES) {
        err(e) => err("fix_loop: " + e)
        ok(result) => {
          print_result(result)
          match write_metrics(result) {
            ok(path) => println("\nReport: " + path)
            err(e) => println("\nWarning: failed to write report: " + e)
          }
          ok(result)
        }
      }
    }
  }
}

// ── Run all tasks ──

fn filter_dotfiles(entries: List[String]) -> List[String] =
  list.filter(entries, (e) => not string.starts_with(e, "."))

effect fn list_all_tasks() -> Result[List[String], String] = {
  let basic = match fs.list_dir("tasks/basic") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let intermediate = match fs.list_dir("tasks/intermediate") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let advanced = match fs.list_dir("tasks/advanced") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let all = (basic + intermediate + advanced) |> list.sort
  if list.is_empty(all) then err("no tasks found")
  else ok(all)
}

let CATEGORY_ORDER = [
  "pass-1shot", "pass-retry",
  "parse-error", "type-error", "name-error", "import-error",
  "compile-error", "runtime-error", "wrong-output", "timeout", "unknown",
]

fn render_summary(date: String, model: String, results: List[RunResult]) -> String = {
  let total = list.len(results)
  let passed = list.count(results, (r) => r.success)
  let one_shot = list.count(results, (r) => r.success and r.retries == 0)
  let total_retries = results
    |> list.map((r) => r.retries)
    |> list.sum

  let rows = results
    |> list.map((r) => {
      let c = classify(r)
      let success_mark = if r.success then "pass" else "FAIL"
      let code_cell = if c.1 == "" then "—" else "`" + c.1 + "`"
      "| `" + r.task + "` | " + success_mark + " | " + c.0 + " | " + code_cell + " | " + int.to_string(r.retries) + " |"
    })
    |> string.join("\n")

  let cat_lines = CATEGORY_ORDER
    |> list.filter_map((cat) => {
      let n = list.count(results, (r) => classify(r).0 == cat)
      if n > 0 then some("- " + cat + ": " + int.to_string(n)) else none
    })
    |> string.join("\n")

  let codes = results
    |> list.map((r) => classify(r).1)
    |> list.filter((c) => c != "")
  let unique_codes = list.unique(codes) |> list.sort
  let code_lines = unique_codes
    |> list.map((code) => "- `" + code + "`: " + int.to_string(list.count(codes, (c) => c == code)))
    |> string.join("\n")
  let codes_section = if list.is_empty(unique_codes) then ""
    else "\n## Top diagnostic codes\n\n" + code_lines + "\n"

  "# MSR run " + date + "\n\n" +
  "- **model**: `" + model + "`\n" +
  "- **tasks**: " + int.to_string(total) + "\n" +
  "- **passed**: " + int.to_string(passed) + " / " + int.to_string(total) + "\n" +
  "- **1-shot passes**: " + int.to_string(one_shot) + " / " + int.to_string(total) + "\n" +
  "- **total retries**: " + int.to_string(total_retries) + "\n\n" +
  "## Per-task\n\n" +
  "| task | result | category | code | retries |\n" +
  "|---|---|---|---|---|\n" +
  rows + "\n\n" +
  "## By category\n\n" + cat_lines + "\n" +
  codes_section
}

effect fn write_summary(date: String, model: String, results: List[RunResult]) -> Result[String, String] = {
  let slug = model_slug(model)
  let dir = "runs/" + date + "/" + slug
  match fs.mkdir_p(dir) {
    err(_) => err("failed to create " + dir)
    ok(_) => {
      let path = dir + "/summary.md"
      match fs.write(path, render_summary(date, model, results)) {
        err(_) => err("failed to write " + path)
        ok(_) => ok(path)
      }
    }
  }
}

// ── Backfill ──
//
// Re-render historical runs/<date>/[<model>/]summary.md from per-task .md
// files using the current classifier. Lets the dashboard show diagnostic
// breakdowns without waiting for the next scheduled CI run.

fn parse_field_from_lines(lines: List[String], prefix: String) -> String =
  lines
    |> list.find((line) => string.contains(line, prefix))
    |> option.map((line) => {
      let after = string.drop(line, string.index_of(line, prefix) |> option.unwrap_or(0) + string.len(prefix))
      string.trim(after) |> string.replace("`", "")
    })
    |> option.unwrap_or("")

fn parse_int_from_lines(lines: List[String], prefix: String) -> Int = {
  let raw = parse_field_from_lines(lines, prefix)
  let num = if string.contains(raw, "/") then
    string.trim(string.take(raw, string.index_of(raw, "/") |> option.unwrap_or(0)))
  else if string.contains(raw, " ") then
    string.trim(string.take(raw, string.index_of(raw, " ") |> option.unwrap_or(0)))
  else raw
  match int.parse(num) { ok(n) => n, err(_) => 0 }
}

fn extract_final_diagnostic(content: String) -> String = {
  let parts = string.split(content, "**Diagnostic:**")
  if list.len(parts) <= 1 then ""
  else {
    let last = list.get(parts, list.len(parts) - 1) |> option.unwrap_or("")
    match string.index_of(last, "```") {
      none => ""
      some(i) => {
        let after_open = string.drop(last, i + 3)
        let body_start = match string.index_of(after_open, "\n") {
          some(j) => string.drop(after_open, j + 1)
          none => after_open
        }
        match string.index_of(body_start, "```") {
          none => string.trim(body_start)
          some(k) => string.trim(string.take(body_start, k))
        }
      }
    }
  }
}

fn task_name_from_filename(filename: String) -> String =
  if string.ends_with(filename, ".md") then
    string.take(filename, string.len(filename) - 3)
  else filename

fn parse_task_md(filename: String, content: String) -> RunResult = {
  let lines = string.split(content, "\n")
  let success_str = parse_field_from_lines(lines, "**success**: ")
  let retries = parse_int_from_lines(lines, "**retries**: ")
  let model = parse_field_from_lines(lines, "**model**: ")
  let success = success_str == "yes"
  let diag = if success then "" else extract_final_diagnostic(content)
  RunResult {
    task: task_name_from_filename(filename),
    model: model,
    success: success,
    retries: retries,
    final_diagnostic: diag,
    final_code: "",
    attempts: [],
  }
}

effect fn backfill_dir(date: String, dir: String) -> Unit = {
  match fs.list_dir(dir) {
    err(_) => println("  skip (cannot list): " + dir)
    ok(entries) => {
      let task_files = entries
        |> list.filter((e) => string.ends_with(e, ".md") and e != "summary.md" and e != "README.md")
        |> list.sort
      let results = task_files
        |> list.filter_map((f) =>
          match fs.read_text(dir + "/" + f) {
            ok(content) => some(parse_task_md(f, content))
            err(_) => none
          })
      if list.is_empty(results) then
        println("  skip (no task reports): " + dir)
      else {
        let model = list.get(results, 0)
          |> option.map((r) => r.model)
          |> option.unwrap_or("unknown")
        let path = dir + "/summary.md"
        match fs.write(path, render_summary(date, model, results)) {
          ok(_) => println("  wrote " + path + " (" + int.to_string(list.len(results)) + " tasks)")
          err(e) => println("  failed " + path + ": " + e)
        }
      }
    }
  }
}

effect fn backfill_subs_loop(date: String, parent: String, subs: List[String]) -> Unit =
  if list.is_empty(subs) then {}
  else {
    let sub = list.get(subs, 0) |> option.unwrap_or("")
    let rest = list.drop(subs, 1)
    backfill_dir(date, parent + "/" + sub)
    backfill_subs_loop(date, parent, rest)
  }

effect fn backfill_loop(dates: List[String]) -> Unit =
  if list.is_empty(dates) then {}
  else {
    let date = list.get(dates, 0) |> option.unwrap_or("")
    let rest = list.drop(dates, 1)
    println("[" + date + "]")
    match fs.read_text("runs/" + date + "/summary.md") {
      ok(_) => { backfill_dir(date, "runs/" + date); {} }
      err(_) =>
        match fs.list_dir("runs/" + date) {
          err(_) => { println("  skip (no subdirs)"); {} }
          ok(subs) => { backfill_subs_loop(date, "runs/" + date, subs); {} }
        }
    }
    backfill_loop(rest)
  }

effect fn backfill_all() -> Unit = {
  match fs.list_dir("runs") {
    err(_) => {
      println("No runs/ directory found")
      process.exit(1)
    }
    ok(entries) => {
      let dates = entries
        |> list.filter((e) => not string.starts_with(e, ".") and e != "README.md")
        |> list.sort
      println("Backfilling " + int.to_string(list.len(dates)) + " date dirs...")
      backfill_loop(dates)
      println("Done.")
    }
  }
}

effect fn run_all(model: String) -> Unit = {
  match list_all_tasks() {
    err(e) => {
      println("Failed to list tasks: " + e)
      process.exit(1)
    }
    ok(tasks) => {
      let sorted = list.sort(tasks)
      println("Running " + int.to_string(list.len(sorted)) + " tasks against " + model)
      println("")
      match run_all_loop(sorted, model, []) {
        err(e) => {
          println("Harness error: " + e)
          process.exit(1)
        }
        ok(results) => {
          let date = datetime.format(env.unix_timestamp(), "YYYY-MM-DD")
          run_all_finish(date, model, results)
        }
      }
    }
  }
}

effect fn run_all_finish(date: String, model: String, results: List[RunResult]) -> Unit = {
  match write_summary(date, model, results) {
    ok(path) => {
      println("")
      println("Summary: " + path)
      let passed = list.count(results, (r) => r.success)
      let total = list.len(results)
      println(int.to_string(passed) + "/" + int.to_string(total) + " tasks passed")
      if passed < total then process.exit(1) else {}
    }
    err(e) => {
      println("Warning: failed to write summary: " + e)
      process.exit(1)
    }
  }
}

effect fn run_all_loop(tasks: List[String], model: String, acc: List[RunResult]) -> Result[List[RunResult], String] = {
  if list.is_empty(tasks) then ok(acc)
  else {
    let task_name = list.get(tasks, 0) |> option.unwrap_or("")
    let rest = list.drop(tasks, 1)
    println("=== " + task_name + " ===")
    let next_acc = match run_task(task_name, model) {
      ok(r) => acc + [r]
      err(e) => {
        println("  harness error: " + e)
        acc + [RunResult {
          task: task_name,
          model: model,
          success: false,
          retries: 0,
          final_diagnostic: e,
          final_code: "",
          attempts: [],
        }]
      }
    }
    println("")
    run_all_loop(rest, model, next_acc)
  }
}

effect fn main() -> Unit = {
  let args = env.args()
  let argc = list.len(args)
  if argc < 1 then
    print_usage()
  else {
    let first = list.get(args, 0) |> option.unwrap_or("")
    let model = list.get(args, 1) |> option.unwrap_or(DEFAULT_MODEL)
    if first == "all" then
      run_all(model)
    else if first == "backfill" then
      backfill_all()
    else {
      match run_task(first, model) {
        ok(r) => if not r.success then process.exit(1) else {}
        err(e) => {
          println("Harness error: " + e)
          process.exit(1)
        }
      }
    }
  }
}

// ── Tests ──

test "bool_str true is yes" {
  assert_eq(bool_str(true), "yes")
}

test "bool_str false is no" {
  assert_eq(bool_str(false), "no")
}

test "strip_code_fences removes triple backtick lines" {
  let raw = "```almide\nfn f() = 1\n```"
  assert_eq(strip_code_fences(raw), "fn f() = 1")
}

test "strip_code_fences leaves non-fenced text alone" {
  assert_eq(strip_code_fences("plain text"), "plain text")
}

test "render_report contains task name and model" {
  let r = RunResult {
    task: "fizzbuzz",
    model: "claude-sonnet-4-6",
    success: true,
    retries: 0,
    final_diagnostic: "",
    final_code: "fn fizzbuzz(n: Int) -> String = \"1\"",
    attempts: [Attempt { code: "fn fizzbuzz(n: Int) -> String = \"1\"", diagnostic: "", passed: true }],
  }
  let out = render_report(r)
  assert(string.contains(out, "fizzbuzz"))
  assert(string.contains(out, "claude-sonnet-4-6"))
  assert(string.contains(out, "success"))
}

test "primary_diagnostic_code extracts E003" {
  assert_eq(primary_diagnostic_code("error[E003]: undefined variable 'x'"), "E003")
}

test "primary_diagnostic_code returns empty when no code" {
  assert_eq(primary_diagnostic_code("error: Expected identifier"), "")
}

test "classify_failure name-error from E003" {
  let r = classify_failure("error[E003]: undefined variable 'x'")
  assert_eq(r.0, "name-error")
  assert_eq(r.1, "E003")
}

test "classify_failure type-error from E001" {
  let r = classify_failure("error[E001]: type mismatch")
  assert_eq(r.0, "type-error")
  assert_eq(r.1, "E001")
}

test "classify_failure parse-error when only Expected" {
  let r = classify_failure("error: Expected identifier at 1:1")
  assert_eq(r.0, "parse-error")
  assert_eq(r.1, "")
}

test "classify_failure runtime-error from panic" {
  let r = classify_failure("thread 'main' panicked at 'index out of bounds'")
  assert_eq(r.0, "runtime-error")
}

test "classify pass-1shot when success and zero retries" {
  let r = RunResult { task: "x", model: "m", success: true, retries: 0, final_diagnostic: "", final_code: "", attempts: [] }
  assert_eq(classify(r).0, "pass-1shot")
}

test "classify pass-retry when success after retries" {
  let r = RunResult { task: "x", model: "m", success: true, retries: 2, final_diagnostic: "", final_code: "", attempts: [] }
  assert_eq(classify(r).0, "pass-retry")
}

test "model_slug sanitizes provider string" {
  assert_eq(model_slug("cf:@cf/meta/llama-3.3-70b"), "cf_cf_meta_llama-3-3-70b")
  assert_eq(model_slug("claude-sonnet-4-6"), "claude-sonnet-4-6")
  assert_eq(model_slug("anthropic/claude-sonnet-4-6"), "anthropic_claude-sonnet-4-6")
}
