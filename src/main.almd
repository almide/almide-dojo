  """

// ── Types ──

// ── Task loading ──

let DIFFICULTIES = ["basic", "intermediate", "advanced"]

effect fn load_task(name: String) -> Result[Task, String] =
  load_task_search(name, DIFFICULTIES)

effect fn load_task_search(name: String, levels: List[String]) -> Result[Task, String] =
  if list.is_empty(levels) then
    err("task not found: " + name)
  else {
    let level = list.get(levels, 0) |> option.unwrap_or("")
    let dir = "tasks/" + level + "/" + name
    match fs.read_text(dir + "/prompt.md") {
      err(_) => load_task_search(name, list.drop(levels, 1))
      ok(prompt) => match fs.read_text(dir + "/tests.almd") {
        err(_) => load_task_search(name, list.drop(levels, 1))
        ok(tests) => ok(Task { name: name, prompt: prompt, tests: tests, dir: dir })
      }
    }
  }

// ── Model call (via llm module) ──

fn strip_code_fences(s: String) -> String =
  s
    |> string.split("\n")
    |> list.filter((line) => not string.starts_with(string.trim(line), "```"))
    |> string.join("\n")

fn to_almai_spec(model: String) -> String = {
  // "cf:@cf/meta/..." → "cf/@cf/meta/..."
  // "anthropic:claude-..." → "anthropic/claude-..."
  // "claude-sonnet-4-6" (no prefix) → "anthropic/claude-sonnet-4-6"
  let colon = string.index_of(model, ":")
  match colon {
    some(i) => string.take(model, i) + "/" + string.drop(model, i + 1)
    none => if string.starts_with(model, "claude") then "anthropic/" + model
      else if string.starts_with(model, "gpt") then "openai/" + model
      else "openai/" + model
  }
}

effect fn call_model(model: String, user_prompt: String) -> Result[String, String] = {
  let spec = to_almai_spec(model)
  let opts = almai.defaults() |> almai.with_system(SYSTEM_PROMPT)
  let msgs = [almai.user(user_prompt)]
  match almai.call_with(spec, msgs, opts) {
    err(e) => err(e)
    ok(r) => ok(strip_code_fences(r.content))
  }
}

// ── Compile + test ──
//
// `process.exec` returns Err on non-zero exit (stderr is the error string).
// So a non-zero `almide test` run shows up as an Err with the diagnostic,
// which we translate into a successful `AttemptResult { success: false }`.

effect fn compile_and_test(task: Task, solution: String, attempt: Int) -> Result[AttemptResult, String] = {
  let tmp = env.temp_dir() + "/dojo-" + task.name + "-" + int.to_string(attempt) + ".almd"
  let combined = solution + "\n\n" + task.tests
  match fs.write(tmp, combined) {
    err(_) => err("failed to write temp file: " + tmp)
    ok(_) => match process.exec("almide", ["test", tmp]) {
      ok(_) => ok(AttemptResult { success: true, code: solution, diagnostic: "" })
      err(diag) => ok(AttemptResult { success: false, code: solution, diagnostic: diag })
    }
  }
}

// ── Fix loop ──
//
// fix_loop_step distinguishes:
//   - err(_)  — genuine harness failure (claude CLI missing, fs broken). Abort.
//   - ok(RunResult { success: false, ... }) — model couldn't produce passing
//     code within max_retries. Not an error; gets recorded and we move on.

fn build_retry_prompt(original: String, prev_code: String, diag: String) -> String =
  "Original task:\n\n" + original + "\n\n" +
  "You previously wrote this code:\n\n" + prev_code + "\n\n" +
  "It failed to compile or test. Diagnostic output:\n\n" + diag +
  hints.hints_block(diag) + "\n\n" +
  "Fix the code and return ONLY the corrected Almide source. No markdown fences, no explanation."

effect fn attempt_once(
  task: Task,
  model: String,
  user_prompt: String,
  attempt: Int,
) -> Result[AttemptResult, String] = {
  match call_model(model, user_prompt) {
    err(e) => err("call_model: " + e)
    ok(code) => compile_and_test(task, code, attempt)
  }
}

effect fn fix_loop_step(
  task: Task,
  model: String,
  max_retries: Int,
  attempt: Int,
  last_code: String,
  last_diag: String,
  acc: List[Attempt],
) -> Result[RunResult, String] = {
  if attempt > max_retries then
    ok(RunResult {
      task: task.name, model: model, success: false,
      retries: max_retries, final_diagnostic: last_diag, final_code: last_code,
      attempts: acc,
    })
  else {
    let user_prompt =
      if attempt == 0 then task.prompt
      else build_retry_prompt(task.prompt, last_code, last_diag)
    match attempt_once(task, model, user_prompt, attempt) {
      err(e) => err("attempt " + int.to_string(attempt) + ": " + e)
      ok(result) => {
        let this_attempt = Attempt { code: result.code, diagnostic: result.diagnostic, passed: result.success }
        let new_acc = acc + [this_attempt]
        if result.success then
          ok(RunResult {
            task: task.name, model: model, success: true,
            retries: attempt, final_diagnostic: "", final_code: result.code,
            attempts: new_acc,
          })
        else
          fix_loop_step(task, model, max_retries, attempt + 1, result.code, result.diagnostic, new_acc)
      }
    }
  }
}

effect fn fix_loop(task: Task, model: String, max_retries: Int) -> Result[RunResult, String] =
  fix_loop_step(task, model, max_retries, 0, "", "", [])

// ── Metrics recording ──
//
// Per-task markdown report at runs/YYYY-MM-DD/<task>.md.
// Summaries only — raw model outputs are not committed by convention.
// Rendering moved to self.render; this file only writes the files.

fn model_slug(model: String) -> String =
  model
    |> string.replace("/", "_")
    |> string.replace(":", "_")
    |> string.replace("@", "")
    |> string.replace(".", "-")

effect fn write_metrics(result: RunResult) -> Result[String, String] = {
  let date = datetime.format(env.unix_timestamp(), "YYYY-MM-DD")
  let slug = model_slug(result.model)
  let dir = "runs/" + date + "/" + slug
  match fs.mkdir_p(dir) {
    err(_) => err("failed to create " + dir)
    ok(_) => {
      let path = dir + "/" + result.task + ".md"
      match fs.write(path, render.render_report(result)) {
        err(_) => err("failed to write " + path)
        ok(_) => ok(path)
      }
    }
  }
}

// ── CLI ──

fn bool_str(b: Bool) -> String =
  if b then "yes" else "no"

effect fn print_usage() -> Unit = {
  println("Almide Dojo harness")
  println("")
  println("Usage:")
  println("  almide run src/main.almd -- <task-name> [provider:model]")
  println("  almide run src/main.almd -- all [provider:model]")
  println("")
  println("Providers:")
  println("  cf:@cf/meta/llama-3.3-70b-instruct-fp8-fast")
  println("  anthropic:claude-sonnet-4-6")
  println("  openrouter:meta-llama/llama-3.3-70b-instruct")
  println("  openai:gpt-4o")
  println("  claude-sonnet-4-6  (Claude CLI, no prefix)")
}

effect fn print_result(result: RunResult) -> Unit = {
  println("")
  println("── Result ──")
  println("  task:    " + result.task)
  println("  model:   " + result.model)
  println("  success: " + bool_str(result.success))
  println("  retries: " + int.to_string(result.retries))
  if result.success then {
    println("")
    println("Task passed.")
  } else {
    println("")
    println("Final diagnostic:")
    println(result.final_diagnostic)
  }
}

effect fn run_task(task_name: String, model: String) -> Result[RunResult, String] = {
  println("Loading task: " + task_name)
  match load_task(task_name) {
    err(e) => err("load task: " + e)
    ok(task) => {
      println("Model:    " + model)
      println("Retries:  " + int.to_string(DEFAULT_MAX_RETRIES))
      println("")
      match fix_loop(task, model, DEFAULT_MAX_RETRIES) {
        err(e) => err("fix_loop: " + e)
        ok(result) => {
          print_result(result)
          match write_metrics(result) {
            ok(path) => println("\nReport: " + path)
            err(e) => println("\nWarning: failed to write report: " + e)
          }
          ok(result)
        }
      }
    }
  }
}

// ── Run all tasks ──

fn filter_dotfiles(entries: List[String]) -> List[String] =
  list.filter(entries, (e) => not string.starts_with(e, "."))

effect fn list_all_tasks() -> Result[List[String], String] = {
  let basic = match fs.list_dir("tasks/basic") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let intermediate = match fs.list_dir("tasks/intermediate") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let advanced = match fs.list_dir("tasks/advanced") {
    err(_) => []
    ok(entries) => filter_dotfiles(entries)
  }
  let all = (basic + intermediate + advanced) |> list.sort
  if list.is_empty(all) then err("no tasks found")
  else ok(all)
}

effect fn write_summary(date: String, model: String, results: List[RunResult]) -> Result[String, String] = {
  let slug = model_slug(model)
  let dir = "runs/" + date + "/" + slug
  match fs.mkdir_p(dir) {
    err(_) => err("failed to create " + dir)
    ok(_) => {
      let path = dir + "/summary.md"
      match fs.write(path, render.render_summary(date, model, results)) {
        err(_) => err("failed to write " + path)
        ok(_) => ok(path)
      }
    }
  }
}

effect fn run_all(model: String) -> Unit = {
  match list_all_tasks() {
    err(e) => {
      println("Failed to list tasks: " + e)
      process.exit(1)
    }
    ok(tasks) => {
      let sorted = list.sort(tasks)
      println("Running " + int.to_string(list.len(sorted)) + " tasks against " + model)
      println("")
      match run_all_loop(sorted, model, []) {
        err(e) => {
          println("Harness error: " + e)
          process.exit(1)
        }
        ok(results) => {
          let date = datetime.format(env.unix_timestamp(), "YYYY-MM-DD")
          run_all_finish(date, model, results)
        }
      }
    }
  }
}

effect fn run_all_finish(date: String, model: String, results: List[RunResult]) -> Unit = {
  match write_summary(date, model, results) {
    ok(path) => {
      println("")
      println("Summary: " + path)
      let passed = list.count(results, (r) => r.success)
      let total = list.len(results)
      println(int.to_string(passed) + "/" + int.to_string(total) + " tasks passed")
      if passed < total then process.exit(1) else {}
    }
    err(e) => {
      println("Warning: failed to write summary: " + e)
      process.exit(1)
    }
  }
}

effect fn run_all_loop(tasks: List[String], model: String, acc: List[RunResult]) -> Result[List[RunResult], String] = {
  if list.is_empty(tasks) then ok(acc)
  else {
    let task_name = list.get(tasks, 0) |> option.unwrap_or("")
    let rest = list.drop(tasks, 1)
    println("=== " + task_name + " ===")
    let next_acc = match run_task(task_name, model) {
      ok(r) => acc + [r]
      err(e) => {
        println("  harness error: " + e)
        acc + [RunResult {
          task: task_name,
          model: model,
          success: false,
          retries: 0,
          final_diagnostic: e,
          final_code: "",
          attempts: [],
        }]
      }
    }
    println("")
    run_all_loop(rest, model, next_acc)
  }
}

effect fn main() -> Unit = {
  let args = env.args()
  let argc = list.len(args)
  if argc < 1 then
    print_usage()
  else {
    let first = list.get(args, 0) |> option.unwrap_or("")
    let model = list.get(args, 1) |> option.unwrap_or(DEFAULT_MODEL)
    if first == "all" then
      run_all(model)
    else if first == "backfill" then
      backfill.backfill_all()
    else {
      match run_task(first, model) {
        ok(r) => if not r.success then process.exit(1) else {}
        err(e) => {
          println("Harness error: " + e)
          process.exit(1)
        }
      }
    }
  }
}

// ── Tests ──

test "bool_str true is yes" {
  assert_eq(bool_str(true), "yes")
}

test "bool_str false is no" {
  assert_eq(bool_str(false), "no")
}

test "strip_code_fences removes triple backtick lines" {
  let raw = "```almide\nfn f() = 1\n```"
  assert_eq(strip_code_fences(raw), "fn f() = 1")
}

test "strip_code_fences leaves non-fenced text alone" {
  assert_eq(strip_code_fences("plain text"), "plain text")
}

test "render_report contains task name and model" {
  let r = RunResult {
    task: "fizzbuzz",
    model: "claude-sonnet-4-6",
    success: true,
    retries: 0,
    final_diagnostic: "",
    final_code: "fn fizzbuzz(n: Int) -> String = \"1\"",
    attempts: [Attempt { code: "fn fizzbuzz(n: Int) -> String = \"1\"", diagnostic: "", passed: true }],
  }
  let out = render.render_report(r)
  assert(string.contains(out, "fizzbuzz"))
  assert(string.contains(out, "claude-sonnet-4-6"))
  assert(string.contains(out, "success"))
}

test "model_slug sanitizes provider string" {
  assert_eq(model_slug("cf:@cf/meta/llama-3.3-70b"), "cf_cf_meta_llama-3-3-70b")
  assert_eq(model_slug("claude-sonnet-4-6"), "claude-sonnet-4-6")
  assert_eq(model_slug("anthropic/claude-sonnet-4-6"), "anthropic_claude-sonnet-4-6")
}
