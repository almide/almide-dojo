// dojo — Almide Dojo harness
//
// Multi-provider LLM harness for MSR measurement.
// Supports Cloudflare Workers AI, Anthropic, OpenRouter, OpenAI, and Claude CLI.
//
// Usage:
//   almide run src/main.almd -- <task-name> [provider:model]
//   almide run src/main.almd -- all [provider:model]
//
// Model formats:
//   cf:@cf/meta/llama-3.3-70b-instruct-fp8-fast    Cloudflare Workers AI
//   anthropic:claude-sonnet-4-6                      Anthropic Messages API
//   openrouter:meta-llama/llama-3.3-70b-instruct    OpenRouter (100+ models)
//   openai:gpt-4o                                   OpenAI API
//   claude-sonnet-4-6                               Claude CLI (no prefix)
//
// Environment variables (per provider):
//   CF_ACCOUNT_ID, CLOUDFLARE_API_KEY               Cloudflare Workers AI
//   ANTHROPIC_API_KEY                               Anthropic / Claude CLI
//   OPENROUTER_API_KEY                              OpenRouter
//   OPENAI_API_KEY                                  OpenAI

import env
import fs
import process
import datetime
import almai
import self.types.{Task, Attempt, RunResult, AttemptResult}
import self.classifier
import self.hints
import self.render
import self.backfill

// ── Constants ──

let DEFAULT_MODEL = "claude-sonnet-4-6"
let DEFAULT_MAX_RETRIES = 3

let SYSTEM_PROMPT = """
  You are writing Almide. Output ONLY source code, no fences or prose.

  Syntax:
    fn name(x: T) -> R = expr                 // no `return`; the last expression is the value
    if cond then a else b                     // every `if` used as an expression MUST have `else`
    match v { some(x) => ..., none => ... }   // match must be exhaustive
    (x) => expr                               // LAMBDA: parentheses around params are MANDATORY.
                                              // `x => expr` is a parse error. Always write `(x) =>`.
    Modules use dot, NOT method syntax:
      string.len(s)        not   s.len()
      int.abs(n)           not   n.abs()
      list.map(xs, f)      not   xs.map(f)
      xs |> list.map(f)    is the pipe form for chaining

  Types:
    Option[T]: some(v) / none. Result[T, E]: ok(v) / err(e).
    No Char type — single characters are String.
    int.to_string(n) for int→string. int.parse(s) -> Result[Int, _].

  Lists are immutable:
    Append: xs + [item]            // NOT list.push — that returns Unit (mutates var)
    Reduce: list.fold(xs, init, (acc, x) => ...)   // no foldLeft / foldRight
    Other: list.map, list.filter, list.filter_map, list.flat_map, list.find, list.sort, list.unique

  Common pitfalls (these trip up LLMs the most):
    - DO NOT write `test "..." { ... }` blocks. The harness appends the reference test suite AFTER your code. Emitting your own tests causes duplicate-definition errors (E012). Submit only the fn definitions the task requires.
    - `if cond then a` without `else` yields Unit — every if-as-expression needs `else`
    - `match` arms must all return the SAME type; don't mix `String` and `Int` arms
    - Don't use stdlib module names as locals: `value`, `error`, `string`, `list`, `option` are modules
    - `list.push(xs, x)` is mutation + returns Unit — use `xs + [x]` for immutable append
    - Non-exhaustive match is an error: cover all constructors or use `_` catch-all
    - Calling an `effect fn` (fs, process, env, random, etc.) from a pure `fn` is an error — mark the caller `effect fn`

  Foreign-language idioms that DO NOT WORK in Almide (do not use, even if natural in OCaml/Haskell/JS/Rust):
    - `let x = ... in expr`             // OCaml/Haskell. WRONG. Just: `let x = ...` then the next expression on a new line.
    - `let rec name(...) = ...`         // OCaml. WRONG. Top-level fn: `fn name(...) -> R = ...` (recursion is automatic).
    - `while cond do ... done`          // Pascal/Ruby. WRONG. Pure code: use recursion or `list.fold`.
                                        // In `effect fn` only: `while cond { ... }` (curly braces, no `do`).
    - `for x in xs do ...`              // No for-loop. Use `list.map` / `list.fold` / `list.for_each` (effect fn).
    - `xs.head` `xs.tail` `xs.length`   // No field access on list. Use `list.first(xs)`, `list.drop(xs, 1)`, `list.len(xs)`.
    - `s.length` `s.toUpperCase()`      // No string methods. Use `string.len(s)`, `string.to_upper(s)`.
    - `Some(x)` `None` `Ok` `Err`       // Capitalized constructors are wrong. Use lowercase: `some(x)`, `none`, `ok(x)`, `err(e)`.
    - `return x`                        // No `return`. The last expression of the body IS the value.
    - `n.abs()` `n.toString()`          // No method calls on values. Use `int.abs(n)`, `int.to_string(n)`.
    - `[first, ..rest]` rest-pattern    // Rust/Swift/JS. WRONG. Almide list pattern is fixed-length only.
                                        // For head+tail split: `let head = list.first(xs) |> option.unwrap_or(default)` and `let rest = list.drop(xs, 1)` (or use `list.is_empty(xs)` + explicit first/drop).

  Auto-imported (no `import` needed): string, list, int, float, math, map, result, option, value, set.
  Other (need `import`): fs, env, io, process, json, random, regex, datetime, http, log, testing, error.

  ## Available stdlib API (use ONLY these names — inventing other names like `string.from_code_points` will fail)

  ### string
  - fn string.capitalize(s: String) -> String
  - fn string.chars(s: String) -> List[String]
  - fn string.codepoint(s: String) -> Option[Int]
  - fn string.contains(s: String, sub: String) -> Bool
  - fn string.count(s: String, sub: String) -> Int
  - fn string.drop(s: String, n: Int) -> String
