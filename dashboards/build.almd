// dashboards/build.almd — Generate static HTML dashboard from runs/
//
// Usage:
//   almide run dashboards/build.almd
//
// Reads runs/YYYY-MM-DD/[<model>/]summary.md files and generates dashboards/index.html.
// Supports both legacy single-model layout (runs/<date>/summary.md) and
// multi-model layout (runs/<date>/<model-slug>/summary.md).

import fs
import process

// ── Parse summary.md ──

fn parse_field(lines: List[String], prefix: String) -> String =
  lines
    |> list.find((line) => string.contains(line, prefix))
    |> option.map((line) => {
      let after = string.drop(line, string.index_of(line, prefix) |> option.unwrap_or(0) + string.len(prefix))
      string.trim(after)
        |> string.replace("`", "")
    })
    |> option.unwrap_or("")

fn parse_int_field(lines: List[String], prefix: String) -> Int = {
  let raw = parse_field(lines, prefix)
  let num = if string.contains(raw, "/") then
    string.trim(string.take(raw, string.index_of(raw, "/") |> option.unwrap_or(0)))
  else if string.contains(raw, " ") then
    string.trim(string.take(raw, string.index_of(raw, " ") |> option.unwrap_or(0)))
  else
    raw
  match int.parse(num) { ok(n) => n, err(_) => 0 }
}

fn parse_task_row(line: String) -> (String, String, String, String, Int) = {
  let cols = line
    |> string.split("|")
    |> list.map((c) => string.trim(c))
    |> list.filter((c) => c != "")
  let name = list.get(cols, 0) |> option.unwrap_or("") |> string.replace("`", "")
  let result = list.get(cols, 1) |> option.unwrap_or("")
  let n = list.len(cols)
  // Old format: name | result | retries (3 cols)        → category="" code=""
  // New format: name | result | category | code | retries (5 cols)
  let category = if n >= 5 then list.get(cols, 2) |> option.unwrap_or("") else ""
  let code = if n >= 5 then
    list.get(cols, 3) |> option.unwrap_or("") |> string.replace("`", "") |> string.replace("—", "")
  else ""
  let retries = if n > 0 then list.get(cols, n - 1) |> option.unwrap_or("0") else "0"
  (name, result, category, code, match int.parse(retries) { ok(n) => n, err(_) => 0 })
}

fn parse_task_rows(lines: List[String]) -> List[(String, String, String, String, Int)] =
  lines
    |> list.filter((line) => string.starts_with(string.trim(line), "|") and string.contains(line, "`"))
    |> list.map((line) => parse_task_row(line))

// Parse sections like "## By category" or "## Top diagnostic codes" whose
// bodies are a list of "- key: N" or "- `key`: N" lines.
fn parse_kv_line(line: String) -> (String, Int) = {
  let trimmed = string.trim(line)
  let body = if string.starts_with(trimmed, "- ") then string.drop(trimmed, 2) else trimmed
  match string.index_of(body, ": ") {
    none => ("", 0)
    some(i) => {
      let key = string.take(body, i) |> string.replace("`", "") |> string.trim
      let val_str = string.drop(body, i + 2) |> string.trim
      (key, match int.parse(val_str) { ok(n) => n, err(_) => 0 })
    }
  }
}

fn parse_section_kv(lines: List[String], header: String) -> List[(String, Int)] = {
  let after = lines |> list.drop_while((l) => not string.starts_with(string.trim(l), header))
  if list.is_empty(after) then []
  else {
    let body = list.drop(after, 1)
      |> list.take_while((l) => not string.starts_with(string.trim(l), "## "))
    body
      |> list.filter((l) => string.starts_with(string.trim(l), "- "))
      |> list.map(parse_kv_line)
      |> list.filter((kv) => kv.0 != "")
  }
}

// ── meta.toml tag extraction ──

fn extract_quoted_strings(s: String) -> List[String] =
  string.split(s, "\"")
    |> list.enumerate
    |> list.filter((entry) => entry.0 % 2 == 1)
    |> list.map((entry) => entry.1)

fn parse_meta_tags(content: String) -> List[String] = {
  let lines = string.split(content, "\n")
  match lines |> list.find((l) => string.starts_with(string.trim(l), "tags")) {
    none => []
    some(l) => extract_quoted_strings(l)
  }
}

type TaskMeta = {
  name: String,
  tags: List[String],
}

type DayRun = {
  date: String,
  model: String,
  total: Int,
  passed: Int,
  one_shot: Int,
  total_retries: Int,
  tasks: List[(String, String, String, String, Int)],
  categories: List[(String, Int)],
  codes: List[(String, Int)],
  recoverable_codes: List[(String, Int)],
  retry_dist: List[(String, Int)],
}

fn parse_summary(date: String, content: String) -> DayRun = {
  let lines = string.split(content, "\n")
  DayRun {
    date: date,
    model: parse_field(lines, "**model**: "),
    total: parse_int_field(lines, "**tasks**: "),
    passed: parse_int_field(lines, "**passed**: "),
    one_shot: parse_int_field(lines, "**1-shot passes**: "),
    total_retries: parse_int_field(lines, "**total retries**: "),
    tasks: parse_task_rows(lines),
    categories: parse_section_kv(lines, "## By category"),
    // After moving from "## Top diagnostic codes" to a recoverable /
    // unrecoverable split, the unrecoverable section is the actionable
    // backlog: codes the model could not fix in N retries.
    codes: parse_section_kv(lines, "## Unrecoverable diagnostic codes"),
    recoverable_codes: parse_section_kv(lines, "## Recoverable diagnostic codes"),
    retry_dist: parse_section_kv(lines, "## Retry distribution"),
  }
}

// ── JSON serialization ──

fn run_to_json(run: DayRun) -> String = {
  let tasks_json = run.tasks
    |> list.map((t) =>
      "{\"name\":\"" + t.0 + "\",\"result\":\"" + t.1 + "\",\"category\":\"" + t.2 + "\",\"code\":\"" + t.3 + "\",\"retries\":" + int.to_string(t.4) + "}")
    |> string.join(",")
  let cats_json = run.categories
    |> list.map((c) => "{\"name\":\"" + c.0 + "\",\"count\":" + int.to_string(c.1) + "}")
    |> string.join(",")
  let codes_json = run.codes
    |> list.map((c) => "{\"code\":\"" + c.0 + "\",\"count\":" + int.to_string(c.1) + "}")
    |> string.join(",")
  let recov_json = run.recoverable_codes
    |> list.map((c) => "{\"code\":\"" + c.0 + "\",\"count\":" + int.to_string(c.1) + "}")
    |> string.join(",")
  let dist_json = run.retry_dist
    |> list.map((c) => "{\"key\":\"" + c.0 + "\",\"count\":" + int.to_string(c.1) + "}")
    |> string.join(",")
  "{" +
    "\"date\":\"" + run.date + "\"," +
    "\"model\":\"" + run.model + "\"," +
    "\"total\":" + int.to_string(run.total) + "," +
    "\"passed\":" + int.to_string(run.passed) + "," +
    "\"oneShot\":" + int.to_string(run.one_shot) + "," +
    "\"totalRetries\":" + int.to_string(run.total_retries) + "," +
    "\"tasks\":[" + tasks_json + "]," +
    "\"categories\":[" + cats_json + "]," +
    "\"codes\":[" + codes_json + "]," +
    "\"recoverable\":[" + recov_json + "]," +
    "\"retryDist\":[" + dist_json + "]" +
  "}"
}

// ── HTML generation ──

fn meta_to_json(m: TaskMeta) -> String = {
  let tags_json = m.tags
    |> list.map((t) => "\"" + t + "\"")
    |> string.join(",")
  "\"" + m.name + "\":[" + tags_json + "]"
}

fn generate_html(runs: List[DayRun], metas: List[TaskMeta]) -> String = {
  let data_json = runs
    |> list.map((r) => run_to_json(r))
    |> string.join(",")
  let metas_json = metas
    |> list.map(meta_to_json)
    |> string.join(",")

  let css = "* { margin: 0; padding: 0; box-sizing: border-box; } " +
    "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; padding: 2rem; } " +
    "h1 { font-size: 1.5rem; margin-bottom: 0.5rem; color: #58a6ff; } " +
    ".subtitle { color: #8b949e; margin-bottom: 2rem; font-size: 0.9rem; } " +
    ".grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; } " +
    ".card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; } " +
    ".card h2 { font-size: 1rem; color: #8b949e; margin-bottom: 1rem; } " +
    ".metric { font-size: 2.5rem; font-weight: 700; } " +
    ".metric.green { color: #3fb950; } .metric.yellow { color: #d29922; } .metric.blue { color: #58a6ff; } " +
    ".chart-box { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; } " +
    ".chart-box h2 { font-size: 1rem; color: #8b949e; margin-bottom: 1rem; } " +
    "table { width: 100%; border-collapse: collapse; font-size: 0.85rem; } " +
    "th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid #21262d; } " +
    "th { color: #8b949e; font-weight: 600; } " +
    ".pass { color: #3fb950; } .fail { color: #f85149; } " +
    ".tag { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.75rem; font-weight: 600; } " +
    ".tag.pass { background: #0d2818; } .tag.fail { background: #3d1418; } " +
    ".card .sub { color: #8b949e; font-size: 0.8rem; margin-top: 0.5rem; } " +
    ".model-head { margin: 1rem 0 0.5rem; color: #8b949e; font-size: 0.9rem; font-weight: 600; } " +
    ".model-head:first-child { margin-top: 0; } " +
    ".heatmap { font-size: 0.7rem; border-collapse: collapse; width: 100%; } " +
    ".heatmap th, .heatmap td { padding: 0.35rem 0.5rem; border: 1px solid #21262d; text-align: center; } " +
    ".heatmap thead th { color: #8b949e; font-weight: 600; writing-mode: vertical-rl; transform: rotate(180deg); height: 7em; vertical-align: bottom; } " +
    ".heatmap tbody th { text-align: left; font-weight: 500; color: #c9d1d9; padding: 0.4rem 0.75rem; writing-mode: horizontal-tb; transform: none; height: auto; } " +
    ".heatmap td.na { color: #6e7681; background: #0d1117; } " +
    ".heatmap td.cell { color: #fff; font-weight: 600; } " +
    "canvas { max-height: 300px; }"

  // JS uses no template literals to avoid Almide interpolation conflicts.
  // Built via string.join to avoid Rust format! recursion-limit blowups
  // that hit when concatenating ~80 string literals with `+`.
  let js = string.join([
    "var DATA = [" + data_json + "];",
    "var TASK_TAGS = {" + metas_json + "};",
    "var PALETTE = ['#3fb950','#58a6ff','#d29922','#f85149','#a371f7','#ff7b72','#79c0ff','#ffa657'];",
    "var CAT_COLORS = {",
    "  'pass-1shot':'#3fb950','pass-retry':'#56d364',",
    "  'parse-error':'#a371f7','type-error':'#f85149','name-error':'#ff7b72',",
    "  'import-error':'#79c0ff','compile-error':'#d29922','runtime-error':'#ffa657',",
    "  'wrong-output':'#ec8e2c','timeout':'#8b949e','unknown':'#6e7681'",
    "};",
    "var CAT_ORDER = ['pass-1shot','pass-retry','parse-error','type-error','name-error','import-error','compile-error','runtime-error','wrong-output','timeout','unknown'];",
    "var byModel = {};",
    "DATA.forEach(function(d){ if(!byModel[d.model]) byModel[d.model]=[]; byModel[d.model].push(d); });",
    "var allDates = Array.from(new Set(DATA.map(function(d){return d.date;}))).sort();",
    "var models = Object.keys(byModel).sort();",
    "var latestDate = allDates[allDates.length - 1];",
    "var latestEntries = DATA.filter(function(d){ return d.date === latestDate; })",
    "  .sort(function(a,b){ return a.model < b.model ? -1 : 1; });",
    "if (latestEntries.length > 0) {",
    "  document.getElementById('metrics').innerHTML = latestEntries.map(function(d){",
    "    var pct = d.total > 0 ? Math.round(100 * d.passed / d.total) : 0;",
    "    var os = d.total > 0 ? Math.round(100 * d.oneShot / d.total) : 0;",
    "    return '<div class=\"card\"><h2>' + d.model + '</h2>' +",
    "      '<div class=\"metric green\">' + pct + '%</div>' +",
    "      '<div class=\"sub\">' + d.passed + '/' + d.total + ' pass · 1-shot ' + os + '% · retries ' + d.totalRetries + '</div></div>';",
    "  }).join('');",
    "}",
    "if (DATA.length > 0) {",
    "  var passDatasets = models.map(function(model, i){",
    "    var byDate = {};",
    "    byModel[model].forEach(function(d){ byDate[d.date] = d; });",
    "    return {",
    "      label: model,",
    "      data: allDates.map(function(dt){ var d = byDate[dt]; return d && d.total > 0 ? Math.round(100 * d.passed / d.total) : null; }),",
    "      borderColor: PALETTE[i % PALETTE.length],",
    "      backgroundColor: PALETTE[i % PALETTE.length],",
    "      tension: 0.3,",
    "      spanGaps: true",
    "    };",
    "  });",
    "  new Chart(document.getElementById('passChart'), {",
    "    type: 'line',",
    "    data: { labels: allDates, datasets: passDatasets },",
    "    options: { scales: { y: { min: 0, max: 100, ticks: { color: '#8b949e' } }, x: { ticks: { color: '#8b949e' } } }, plugins: { legend: { labels: { color: '#c9d1d9' } } } }",
    "  });",
    "}",
    "if (latestEntries.length > 0) {",
    "  var retryLabels = ['after 0', 'after 1', 'after 2', 'after 3'];",
    "  var retryDatasets = latestEntries.map(function(d, i){",
    "    var byKey = {};",
    "    (d.retryDist || []).forEach(function(c){ byKey[c.key] = c.count; });",
    "    var passed_at = [0,1,2,3].map(function(n){ return byKey['pass-' + n] || 0; });",
    "    var cum = [];",
    "    var run = 0;",
    "    passed_at.forEach(function(v){ run += v; cum.push(d.total > 0 ? Math.round(100 * run / d.total) : 0); });",
    "    return { label: d.model, data: cum, borderColor: PALETTE[i % PALETTE.length], backgroundColor: PALETTE[i % PALETTE.length], tension: 0.2 };",
    "  });",
    "  new Chart(document.getElementById('retryChart'), {",
    "    type: 'line',",
    "    data: { labels: retryLabels, datasets: retryDatasets },",
    "    options: { scales: { y: { min: 0, max: 100, ticks: { color: '#8b949e' } }, x: { ticks: { color: '#8b949e' } } }, plugins: { legend: { labels: { color: '#c9d1d9' } } } }",
    "  });",
    "}",
    "if (latestEntries.length > 0) {",
    "  var catDatasets = CAT_ORDER.map(function(cat){",
    "    return {",
    "      label: cat,",
    "      data: latestEntries.map(function(d){",
    "        var hit = (d.categories || []).find(function(c){ return c.name === cat; });",
    "        return hit ? hit.count : 0;",
    "      }),",
    "      backgroundColor: CAT_COLORS[cat] || '#6e7681'",
    "    };",
    "  }).filter(function(ds){ return ds.data.some(function(n){ return n > 0; }); });",
    "  new Chart(document.getElementById('catChart'), {",
    "    type: 'bar',",
    "    data: { labels: latestEntries.map(function(d){ return d.model; }), datasets: catDatasets },",
    "    options: { indexAxis: 'y', scales: { x: { stacked: true, ticks: { color: '#8b949e' } }, y: { stacked: true, ticks: { color: '#8b949e', font: { size: 11 } } } }, plugins: { legend: { labels: { color: '#c9d1d9', boxWidth: 12 } } } }",
    "  });",
    "}",
    "function aggregateCodes(field) {",
    "  var agg = {};",
    "  latestEntries.forEach(function(d){",
    "    (d[field] || []).forEach(function(c){ agg[c.code] = (agg[c.code] || 0) + c.count; });",
    "  });",
    "  return Object.keys(agg)",
    "    .map(function(k){ return { code: k, count: agg[k] }; })",
    "    .sort(function(a,b){ return b.count - a.count; })",
    "    .slice(0, 10);",
    "}",
    "function renderCodesChart(canvasId, boxId, codes, color, label) {",
    "  if (codes.length > 0) {",
    "    new Chart(document.getElementById(canvasId), {",
    "      type: 'bar',",
    "      data: { labels: codes.map(function(c){ return c.code; }), datasets: [{ label: label, data: codes.map(function(c){ return c.count; }), backgroundColor: color }] },",
    "      options: { scales: { y: { ticks: { color: '#8b949e' }, beginAtZero: true }, x: { ticks: { color: '#8b949e' } } }, plugins: { legend: { display: false } } }",
    "    });",
    "  } else {",
    "    document.getElementById(boxId).style.display = 'none';",
    "  }",
    "}",
    "if (latestEntries.length > 0) {",
    "  renderCodesChart('codesChart', 'codesBox', aggregateCodes('codes'), '#f85149', 'Unrecoverable failures');",
    "  renderCodesChart('recovChart', 'recovBox', aggregateCodes('recoverable'), '#3fb950', 'Recovered after retry');",
    "}",
    "if (latestEntries.length > 0) {",
    "  var allTags = Array.from(new Set([].concat.apply([], Object.values(TASK_TAGS)))).sort();",
    "  var heatHtml = '<table class=\"heatmap\"><thead><tr><th></th>';",
    "  allTags.forEach(function(tag){ heatHtml += '<th>' + tag + '</th>'; });",
    "  heatHtml += '</tr></thead><tbody>';",
    "  latestEntries.forEach(function(d){",
    "    heatHtml += '<tr><th>' + d.model + '</th>';",
    "    allTags.forEach(function(tag){",
    "      var matching = d.tasks.filter(function(t){ return (TASK_TAGS[t.name] || []).indexOf(tag) >= 0; });",
    "      if (matching.length === 0) {",
    "        heatHtml += '<td class=\"na\">—</td>';",
    "      } else {",
    "        var passed = matching.filter(function(t){ return t.result === 'pass'; }).length;",
    "        var pct = Math.round(100 * passed / matching.length);",
    "        var hue = Math.round(pct * 1.2);",
    "        heatHtml += '<td class=\"cell\" style=\"background:hsl(' + hue + ',55%,28%)\" title=\"' + passed + '/' + matching.length + ' (' + pct + '%)\">' + passed + '/' + matching.length + '</td>';",
    "      }",
    "    });",
    "    heatHtml += '</tr>';",
    "  });",
    "  heatHtml += '</tbody></table>';",
    "  document.getElementById('tagHeatmap').innerHTML = heatHtml;",
    "}",
    "if (latestEntries.length > 0) {",
    "  document.getElementById('taskTable').innerHTML = latestEntries.map(function(d){",
    "    var rows = d.tasks.map(function(t){",
    "      var cls = t.result === 'pass' ? 'pass' : 'fail';",
    "      var catCell = t.category ? '<span class=\"tag\" style=\"background:' + (CAT_COLORS[t.category] || '#6e7681') + '22;color:' + (CAT_COLORS[t.category] || '#c9d1d9') + '\">' + t.category + '</span>' : '';",
    "      var codeCell = t.code ? '<code>' + t.code + '</code>' : '—';",
    "      return '<tr><td>' + t.name + '</td><td><span class=\"tag ' + cls + '\">' + t.result + '</span></td><td>' + catCell + '</td><td>' + codeCell + '</td><td>' + t.retries + '</td></tr>';",
    "    }).join('');",
    "    return '<h3 class=\"model-head\">' + d.model + '</h3>' +",
    "      '<table><thead><tr><th>Task</th><th>Result</th><th>Category</th><th>Code</th><th>Retries</th></tr></thead><tbody>' + rows + '</tbody></table>';",
    "  }).join('');",
    "}",
  ], "")

  "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n" +
  "<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n" +
  "<title>Almide Dojo — MSR Dashboard</title>\n" +
  "<script src=\"https://cdn.jsdelivr.net/npm/chart.js@4\"></script>\n" +
  "<style>" + css + "</style>\n" +
  "</head>\n<body>\n" +
  "<h1>Almide Dojo — MSR Dashboard</h1>\n" +
  "<p class=\"subtitle\">Modification Survival Rate across LLM models</p>\n" +
  "<div class=\"grid\" id=\"metrics\"></div>\n" +
  "<div class=\"chart-box\"><h2>Pass Rate Over Time</h2><canvas id=\"passChart\"></canvas></div>\n" +
  "<div class=\"chart-box\"><h2>Cumulative Pass Rate by Retry Count (Latest Run)</h2><p style=\"color:#8b949e;font-size:0.85rem;margin-bottom:1rem\">Does the diagnostic loop converge with more retries? Flat tail = retries no longer help.</p><canvas id=\"retryChart\"></canvas></div>\n" +
  "<div class=\"chart-box\"><h2>Failure Breakdown by Category (Latest Run)</h2><canvas id=\"catChart\"></canvas></div>\n" +
  "<div class=\"chart-box\" id=\"codesBox\"><h2>Unrecoverable Diagnostic Codes — backlog for almide compiler (latest day, all models)</h2><p style=\"color:#8b949e;font-size:0.85rem;margin-bottom:1rem\">Codes that LLMs could not recover from in 3 retries. Each one is a candidate for clearer hint text or compiler fix.</p><canvas id=\"codesChart\"></canvas></div>\n" +
  "<div class=\"chart-box\" id=\"recovBox\"><h2>Recoverable Diagnostic Codes — diagnostic worked (latest day, all models)</h2><p style=\"color:#8b949e;font-size:0.85rem;margin-bottom:1rem\">Codes the model fixed after seeing the diagnostic. These hints already do their job.</p><canvas id=\"recovChart\"></canvas></div>\n" +
  "<div class=\"chart-box\"><h2>Pass Rate by Almide Feature × Model (Latest Run)</h2><div id=\"tagHeatmap\" style=\"overflow-x:auto\"></div></div>\n" +
  "<div class=\"chart-box\"><h2>Per-Task Results (Latest Run)</h2><div id=\"taskTable\"></div></div>\n" +
  "<script>" + js + "</script>\n" +
  "</body>\n</html>"
}

// ── Main ──

effect fn main() -> Unit = {
  match fs.list_dir("runs") {
    err(_) => {
      println("No runs/ directory found")
      process.exit(1)
    }
    ok(entries) => {
      let dates = entries
        |> list.filter((e) => not string.starts_with(e, ".") and e != "README.md")
        |> list.sort
      let runs = dates
        |> list.flat_map((date) =>
          match fs.read_text("runs/" + date + "/summary.md") {
            ok(content) => [parse_summary(date, content)]
            err(_) =>
              match fs.list_dir("runs/" + date) {
                err(_) => []
                ok(subs) => subs
                  |> list.filter_map((sub) =>
                    match fs.read_text("runs/" + date + "/" + sub + "/summary.md") {
                      ok(content) => some(parse_summary(date, content))
                      err(_) => none
                    })
              }
          })
      if list.is_empty(runs) then {
        println("No summary files found")
        process.exit(1)
      } else {
        let tiers = ["basic", "intermediate", "advanced"]
        let metas = tiers
          |> list.flat_map((tier) =>
            match fs.list_dir("tasks/" + tier) {
              err(_) => []
              ok(names) => names
                |> list.filter_map((name) =>
                  match fs.read_text("tasks/" + tier + "/" + name + "/meta.toml") {
                    ok(content) => some(TaskMeta { name: name, tags: parse_meta_tags(content) })
                    err(_) => none
                  })
            })
        let html = generate_html(runs, metas)
        match fs.write("dashboards/index.html", html) {
          ok(_) => println("Generated dashboards/index.html (" + int.to_string(list.len(runs)) + " runs, " + int.to_string(list.len(metas)) + " task metas)")
          err(e) => {
            println("Failed to write: " + e)
            process.exit(1)
          }
        }
      }
    }
  }
}

// ── Tests ──

test "parse_field extracts model" {
  let lines = ["- **model**: `claude-sonnet-4-6`", "- **tasks**: 5"]
  assert_eq(parse_field(lines, "**model**: "), "claude-sonnet-4-6")
}

test "parse_int_field extracts passed" {
  let lines = ["- **passed**: 3 / 5"]
  assert_eq(parse_int_field(lines, "**passed**: "), 3)
}

test "parse_int_field extracts tasks" {
  let lines = ["- **tasks**: 5"]
  assert_eq(parse_int_field(lines, "**tasks**: "), 5)
}

test "parse_task_row extracts columns (3-col legacy)" {
  let row = parse_task_row("| `fizzbuzz` | pass | 0 |")
  assert_eq(row.0, "fizzbuzz")
  assert_eq(row.1, "pass")
  assert_eq(row.2, "")
  assert_eq(row.3, "")
  assert_eq(row.4, 0)
}

test "parse_task_row extracts columns (5-col with category/code)" {
  let row = parse_task_row("| `anagram-check` | FAIL | name-error | `E003` | 3 |")
  assert_eq(row.0, "anagram-check")
  assert_eq(row.1, "FAIL")
  assert_eq(row.2, "name-error")
  assert_eq(row.3, "E003")
  assert_eq(row.4, 3)
}

test "parse_task_row 5-col with em-dash code is empty" {
  let row = parse_task_row("| `clamp` | pass | pass-1shot | — | 0 |")
  assert_eq(row.2, "pass-1shot")
  assert_eq(row.3, "")
}

test "parse_kv_line extracts plain key" {
  let kv = parse_kv_line("- pass-1shot: 6")
  assert_eq(kv.0, "pass-1shot")
  assert_eq(kv.1, 6)
}

test "parse_kv_line strips backticks" {
  let kv = parse_kv_line("- `E003`: 7")
  assert_eq(kv.0, "E003")
  assert_eq(kv.1, 7)
}

test "parse_section_kv finds By category section" {
  let lines = [
    "## Per-task",
    "...",
    "## By category",
    "",
    "- pass-1shot: 5",
    "- type-error: 10",
    "",
    "## Top diagnostic codes",
    "",
    "- `E001`: 2",
  ]
  let cats = parse_section_kv(lines, "## By category")
  assert_eq(list.len(cats), 2)
  let first = list.get(cats, 0) |> option.unwrap_or(("", 0))
  assert_eq(first.0, "pass-1shot")
  assert_eq(first.1, 5)
  let codes = parse_section_kv(lines, "## Top diagnostic codes")
  assert_eq(list.len(codes), 1)
}
