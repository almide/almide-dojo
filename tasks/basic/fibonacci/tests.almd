test "fibonacci 0 is 0" { assert_eq(fibonacci(0), 0) }
test "fibonacci 1 is 1" { assert_eq(fibonacci(1), 1) }
test "fibonacci 2 is 1" { assert_eq(fibonacci(2), 1) }
test "fibonacci 3 is 2" { assert_eq(fibonacci(3), 2) }
test "fibonacci 5 is 5" { assert_eq(fibonacci(5), 5) }
test "fibonacci 10 is 55" { assert_eq(fibonacci(10), 55) }
test "fibonacci 15 is 610" { assert_eq(fibonacci(15), 610) }
