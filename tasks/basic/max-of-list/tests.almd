test "max_of_list empty" { assert_eq(max_of_list([]), none) }
test "max_of_list single" { assert_eq(max_of_list([42]), some(42)) }
test "max_of_list ascending" { assert_eq(max_of_list([1, 2, 3]), some(3)) }
test "max_of_list descending" { assert_eq(max_of_list([3, 2, 1]), some(3)) }
test "max_of_list duplicates" { assert_eq(max_of_list([5, 5, 5]), some(5)) }
test "max_of_list negatives" { assert_eq(max_of_list([-3, -1, -2]), some(-1)) }
test "max_of_list mixed" { assert_eq(max_of_list([-10, 0, 10, 5]), some(10)) }
